NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4001
LOG_LEVEL=info

# Security
API_KEY=replace_with_a_long_random_secret
MAX_PAYLOAD_BYTES=1048576

# Rate limit
RATE_LIMIT_MAX=60
RATE_LIMIT_TIME_WINDOW=1 minute

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_translation_platform?schema=public

# Translation
TRANSLATION_PROVIDER=stub
STUB_TRANSLATION_MODE=annotate
ASYNC_MODE=sync
